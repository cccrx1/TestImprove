{
  "seed": 0,
  "dataset": {
    "name": "cub200",
    "root": "./datasets/cub200",
    "train_subdir": "train",
    "test_subdir": "test",
    "resize_shorter": 256,
    "image_size": 224,
    "normalize": {
      "mean": [
        0.485,
        0.456,
        0.406
      ],
      "std": [
        0.229,
        0.224,
        0.225
      ]
    }
  },
  "model": {
    "name": "torchvision-resnet50",
    "kwargs": {
      "weights": "DEFAULT"
    },
    "checkpoint": null
  },
  "loss": "cross_entropy",
  "schedule": {
    "save_dir": "outputs",
    "dataset_name": "cub200",
    "model_name": "torchvision-resnet50",
    "batch_size": 16,
    "num_workers": 4,
    "epochs": 30,
    "lr": 0.01,
    "momentum": 0.9,
    "weight_decay": 0.0001,
    "test_epoch_interval": 1,
    "save_epoch_interval": 5,
    "device": "GPU"
  }
}
