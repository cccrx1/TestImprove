{
  "seed": 0,
  "dataset": {
    "name": "cub200",
    "root": "./datasets/cub200",
    "train_subdir": "train",
    "test_subdir": "test",
    "resize_shorter": 256,
    "image_size": 224,
    "normalize": {
      "mean": [
        0.485,
        0.456,
        0.406
      ],
      "std": [
        0.229,
        0.224,
        0.225
      ]
    }
  },
  "model": {
    "name": "torchvision-resnet50",
    "kwargs": {
      "weights": "DEFAULT"
    },
    "checkpoint": "./outputs/attacks/cub200/wanet_torchvision-resnet50_wanet_YYYYMMDD_HHMMSS/ckpt_epoch_20.pth"
  },
  "loss": "cross_entropy",
  "attack": {
    "name": "wanet",
    "kwargs": {
      "y_target": 0,
      "poisoned_rate": 0.1,
      "noise": true,
      "grid_k": 4,
      "poisoned_transform_train_index": null,
      "poisoned_transform_test_index": null,
      "poisoned_target_transform_index": 0
    }
  },
  "refine": {
    "unet_name": "unet-little",
    "unet_kwargs": {
      "first_channels": 64
    },
    "defense_kwargs": {
      "lmd": 0.05,
      "seed": 0
    }
  },
  "train_unet": true,
  "eval_clean": true,
  "eval_poisoned": true,
  "poisoned_metric": "ASR",
  "schedule": {
    "save_dir": "outputs",
    "dataset_name": "cub200",
    "attack_name": "wanet",
    "model_name": "torchvision-resnet50",
    "defense_name": "refine",
    "batch_size": 16,
    "num_workers": 4,
    "epochs": 15,
    "lr": 0.001,
    "betas": [
      0.9,
      0.999
    ],
    "eps": 1e-08,
    "weight_decay": 0.0,
    "amsgrad": false,
    "schedule": [
      5,
      8
    ],
    "gamma": 0.1,
    "log_iteration_interval": 100,
    "test_epoch_interval": 1,
    "save_epoch_interval": 5,
    "device": "GPU",
    "metric": "clean"
  }
}
