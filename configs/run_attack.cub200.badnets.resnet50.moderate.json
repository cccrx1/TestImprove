{
  "seed": 0,
  "dataset": {
    "name": "cub200",
    "root": "./datasets/cub200",
    "train_subdir": "train",
    "test_subdir": "test",
    "resize_shorter": 256,
    "image_size": 224,
    "normalize": {
      "mean": [0.485, 0.456, 0.406],
      "std": [0.229, 0.224, 0.225]
    }
  },
  "model": {
    "name": "torchvision-resnet50",
    "kwargs": {
      "weights": null
    },
    "checkpoint": "./outputs/cub200/clean/torchvision-resnet50_clean_20260424_114045/ckpt_epoch_50.pth"
  },
  "loss": "cross_entropy",
  "attack": {
    "name": "badnets",
    "kwargs": {
      "y_target": 1,
      "poisoned_rate": 0.05,
      "trigger_size": 18,
      "pattern": null,
      "weight": null,
      "poisoned_transform_train_index": null,
      "poisoned_transform_test_index": null,
      "poisoned_target_transform_index": 0
    }
  },
  "run_train": true,
  "run_test": true,
  "schedule": {
    "save_dir": "outputs",
    "batch_size": 16,
    "num_workers": 4,
    "epochs": 30,
    "lr": 0.01,
    "momentum": 0.9,
    "weight_decay": 0.0001,
    "schedule": [15, 24],
    "gamma": 0.1,
    "benign_training": false,
    "log_iteration_interval": 100,
    "test_epoch_interval": 1,
    "save_epoch_interval": 5,
    "device": "GPU",
    "metric": "ASR"
  }
}
