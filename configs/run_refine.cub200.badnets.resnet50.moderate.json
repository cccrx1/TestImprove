{
  "seed": 0,
  "dataset": {
    "name": "cub200",
    "root": "./datasets/cub200",
    "train_subdir": "train",
    "test_subdir": "test",
    "resize_shorter": 256,
    "image_size": 224,
    "normalize": {
      "mean": [0.485, 0.456, 0.406],
      "std": [0.229, 0.224, 0.225]
    }
  },
  "model": {
    "name": "torchvision-resnet50",
    "kwargs": {
      "weights": null
    },
    "checkpoint": "./outputs/cub200/attacks/REPLACE_WITH_MODERATE_BADNETS_RUN/ckpt_epoch_30.pth"
  },
  "loss": "cross_entropy",
  "attack": {
    "name": "badnets",
    "kwargs": {
      "y_target": 1,
      "poisoned_rate": 0.05,
      "trigger_size": 18,
      "pattern": null,
      "weight": null,
      "poisoned_transform_train_index": null,
      "poisoned_transform_test_index": null,
      "poisoned_target_transform_index": 0
    }
  },
  "refine": {
    "unet_name": "unet-little",
    "unet_kwargs": {
      "first_channels": 64
    },
    "defense_name": "refine",
    "defense_kwargs": {
      "lmd": 0.05,
      "enable_label_shuffle": false,
      "norm_mean": [0.485, 0.456, 0.406],
      "norm_std": [0.229, 0.224, 0.225],
      "seed": 0
    }
  },
  "train_unet": true,
  "eval_clean": true,
  "eval_poisoned": true,
  "poisoned_metric": "ASR",
  "schedule": {
    "save_dir": "outputs",
    "batch_size": 16,
    "num_workers": 4,
    "epochs": 15,
    "lr": 0.001,
    "betas": [0.9, 0.999],
    "eps": 1e-08,
    "weight_decay": 0.0,
    "amsgrad": false,
    "schedule": [5, 8],
    "gamma": 0.1,
    "log_iteration_interval": 100,
    "test_epoch_interval": 1,
    "save_epoch_interval": 5,
    "device": "GPU",
    "metric": "clean"
  }
}
