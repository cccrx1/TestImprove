{
  "seed": 0,
  "dataset": {
    "name": "cifar10",
    "root": "./datasets",
    "download": false
  },
  "model": {
    "name": "resnet18",
    "kwargs": {},
    "checkpoint": null
  },
  "loss": "cross_entropy",
  "schedule": {
    "save_dir": "outputs",
