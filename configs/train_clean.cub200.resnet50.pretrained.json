{
  "seed": 0,
  "dataset": {
    "name": "cub200",
    "root": "./datasets/cub200",
    "train_subdir": "train",
    "test_subdir": "test",
    "image_size": 224
  },
  "model": {
    "name": "torchvision-resnet50",
    "kwargs": {
      "weights": "DEFAULT"
    },
    "checkpoint": null
  },
  "loss": "cross_entropy",
  "schedule": {
    "save_dir": "outputs",
    "batch_size": 32,
    "num_workers": 4,
    "epochs": 50,
    "lr": 0.01,
    "momentum": 0.9,
    "weight_decay": 0.0001,
    "schedule": [
      25,
      40
    ],
    "gamma": 0.1,
    "test_epoch_interval": 1,
    "save_epoch_interval": 5,
    "device": "GPU"
  }
}
